<% layout('/layout/boilerplate') -%>
  <h2 class="col-4 offset-3"> sginup for wanderlust</h2>
  <div class="row">
    <div class="col-4 offset-3">
      <form action="/signup" method="post" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label">username</label>
          <input name="username" id="username" type="text" class="form-control" required><br>
          <div class="invalid-feedback">
            looks good
          </div>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">email</label>
          <input name="email" id="email" type="email" class="form-control" required><br>

        </div>
        <div class="mb-3">
          <label for="password" class="form-label">password</label>
          <input name="password" id="password" type="password" class="form-control" required><br>

        </div>
        <button class="btn btn-success">signup</button>
      </form>
    </div>
  </div>