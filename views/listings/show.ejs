<% layout('/layout/boilerplate') -%>
  <div class="row">
    <div class="col-8 offset-2">


      <h3 class="col-6 offset-1">
        <%=listing.title %>
      </h3>
      <div class="card col-6  offset-1 listing-card">
        <img src="<%=listing.image.url %>" class="card-img-top show-img" alt="image">
        <div class="card-body">
          <p class="card-text">
          <p>
            <i>owner:
              <b>
                <%= listing.owner.username%>
              </b>

            </i>
          </p>
          <br>

          <%=listing.description %>
            <br>
            <b> &#8377; <%=(listing.price ?? 0).toLocaleString("en-IN") %> /night</b>
            <br>
            <%=listing.country %>
              <br>
              <%=listing.location %>
                </p>
        </div>
      </div>




      <div class="btns col-6 offset-1">
        <a href="/listings/<%=listing._id %>/edit" class="btn btn-dark edit-btn">Edit </a>
        <br>
        <form method="post" action="/listings/<%=listing._id %>?_method=DELETE">
          <button class="btn btn-dark offset-2">delete</button>



        </form>
      </div>

      <br>
      <div class="col-8 offset-1 mb-3 mt-3">
        <% if(currUser){ %>
          <h4>Leave a review</h4>
          <form action="/listings/<%=listing._id %>/reviews" method="post" novalidate class="needs-validation">
            <hr>

            <!-- <div class="mb-3 mt-3">
              
              <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div> -->

            <div class="mb-3 mt-3">
              <label for="rating" class="form-label">Rating</label>

              <fieldset class="starability-slot">

                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                  aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>

            </div>



            <div class="mb-3 mt-3">
              <label for="comment"> comment</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="6" class="form-control" required></textarea>

              <div class="invalid-feedback">
                Please add some comment
              </div>

            </div>
            <button class="btn btn-outline-dark">submit</button>
          </form>
          <% } %>
            <hr>


            <% for(review of listing.reviews){ %>
              <div class="row">
                <h4><b>All Review</b></h4>
                <div class="card col-5 ms-3 mb-3">
                  <div class="card-body">
                    <h4 class="card-title">
                      <%=review.author.username %>
                    </h4>
                    <p class="starability-result" data-rating="<%=review.rating %>">
                      Rated: <%=review.rating %>
                        <p class="card-text">
                          <%=review.comment %>
                        </p>
                        <p class="card-text">

                        </p>

                    </p>
                    <form method="POST" action="/listings/<%=listing._id %>/reviews/<%=review._id %>?_method=DELETE"
                      class="mb-3">
                      <button class="btn btn-sm btn-dark"> DELETE</button>
                    </form>
                  </div>
                </div>
              </div>
              <% } %>
      </div>
      <div class="col-8 offset-1 mb-3 mt-3">
        <h3>Where you'll be staying</h3>
        <div id="map"></div>
      </div>
    </div>
  </div>
  <!-- <script>
    // TO MAKE THE MAP APPEAR YOU MUST
    // ADD YOUR ACCESS TOKEN FROM
